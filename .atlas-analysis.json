  "keyFeatures": [
    "Polyfills for ECMAScript up to ES2025 (Promise, Symbol, Map, Set, Iterator, TypedArrays, etc.)",
    "Support for ECMAScript proposals from Stage 0 through finished",
    "Web/WHATWG standards polyfills (URL, structuredClone, queueMicrotask, setImmediate, etc.)",
    "Global (core-js) and pollution-free (core-js-pure) variants",
    "Granular per-feature imports for tree-shaking and minimal bundle size",
    "Browserslist-powered compatibility data via core-js-compat",
    "Custom bundle generation via core-js-builder",
    "Integration with Babel (@babel/preset-env, @babel/runtime) and swc",
    "Configurable polyfill aggressiveness via the configurator API",
    "Support for Node.js, browsers, Deno, Bun, Rhino, Hermes, and other JS runtimes"
  ],
  "publicApiSurface": [
    "import 'core-js'",
    "import 'core-js/actual'",
    "import 'core-js/stable'",
    "import 'core-js/es'",
    "import 'core-js/full'",
    "import 'core-js/actual/<feature>'",
    "import 'core-js/proposals/<proposal-name>'",
    "import 'core-js/stage/<stage>'",
    "import Set from 'core-js-pure/actual/set'",
    "import Promise from 'core-js-pure/actual/promise'",
    "compat({ targets, modules, exclude, version }) from 'core-js-compat'",
    "getModulesListForTargetVersion(version) from 'core-js-compat'",
    "builder({ modules, exclude, targets, format, filename, summary }) from 'core-js-builder'",
    "configurator({ useNative, usePolyfill, useFeatureDetection }) from 'core-js/configurator'"
  ]
}
