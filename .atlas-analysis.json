{
  "projectType": "sdk-library",
  "projectName": "core-js",
  "projectDescription": "A modular standard library for JavaScript that provides polyfills for ECMAScript features up to ES2025, stage proposals, and select Web/WHATWG APIs.",
  "theme": "palm",
  "primaryColor": "#ababab",
  "lightColor": "#404040",
